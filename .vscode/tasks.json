{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++.exe build active file",
            "command": "powershell",
            "args": [
                "-Command",
                "if (!(Test-Path '${workspaceFolder}\\exe')) { New-Item -ItemType Directory -Path '${workspaceFolder}\\exe' };",
                "g++.exe",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}\\exe\\${fileBasenameNoExtension}.exe",
                "-DSH_LOCAL"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin" 
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "MSYS2 g++를 사용하여 exe 폴더에 빌드 및 SH_LOCAL 정의"
        }
    ]
}
